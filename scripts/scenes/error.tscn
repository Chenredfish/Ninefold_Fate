[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/scenes/error.gd"]

[node name="ErrorScene" type="Control"]
script = ExtResource("res://scripts/scenes/error.gd")
anchor_left = 0.0
anchor_top = 0.0
anchor_right = 1.0
anchor_bottom = 1.0
layout_mode = 1
theme_override_colors/background_color = Color(0.2, 0.1, 0.1, 1)

[node name="VBoxContainer" type="VBoxContainer" parent="."]
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -150.0
offset_top = -100.0
offset_right = 150.0
offset_bottom = 100.0
layout_mode = 1
theme_override_constants/separation = 20
alignment = 1

[node name="TitleLabel" type="Label" parent="VBoxContainer"]
layout_mode = 2
text = "⚠️ 錯誤"
horizontal_alignment = 1
theme_override_font_sizes/font_size = 32
theme_override_colors/font_color = Color(1, 0.3, 0.3, 1)

[node name="MessageLabel" type="Label" parent="VBoxContainer"]
layout_mode = 2
text = "場景加載失敗

請檢查場景檔案是否存在"
horizontal_alignment = 1
vertical_alignment = 1
autowrap_mode = 3
theme_override_font_sizes/font_size = 16

[node name="BackButton" type="Button" parent="VBoxContainer"]
layout_mode = 2
custom_minimum_size = Vector2(100, 50)
text = "返回主菜單"
theme_override_font_sizes/font_size = 14

[connection signal="pressed" from="VBoxContainer/BackButton" to="." method="_on_back_button_pressed"]
