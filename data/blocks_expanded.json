{
  "_comment": "special_effects: Array[String] 對應 AbilityComponent.create_by_id() 的 ability_id。effect_parameters 由各 AbilityComponent 子類的 setup_parameters() 讀取。",
  "_new_abilities_needed": [
    "damage_multiplier  → DamageMultiplierAbility  (乘上傷害倍率)",
    "countdown_push     → CountdownPushAbility     (加速敵人倒數，是負面效果，用更高傷害補償)",
    "lifesteal          → LifestealAbility         (依英雄 base_attack 百分比回血，不是依傷害)",
    "lifesteal_amplify  → LifestealAmplifyAbility  (本回合所有 lifesteal 倍率乘法)",
    "aoe_damage         → AoeDamageAbility         (傷害分散至所有敵人)",
    "crit_boost         → CritBoostAbility         (提升暴擊率和暴擊傷害倍率)",
    "hp_sacrifice       → HpSacrificeAbility       (扣除自身 HP 換取傷害倍率，HP 不足則跳過)"
  ],
  "_existing_abilities": [
    "heal      → HealAbility      (已實裝)",
    "shield    → ShieldAbility    (已實裝)",
    "burn      → BurnAbility      (已實裝，不建議再使用於火系 - 太複雜)",
    "freeze    → FreezeAbility    (已實裝，水系使用)",
    "debuff_defense → DefenseDebuffAbility (已實裝，暗系使用)"
  ],

